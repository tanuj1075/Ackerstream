POSTGRES_USER=ticketadmin
POSTGRES_PASSWORD=secretpassword_changeme
POSTGRES_DB=ticketbooking

# Optional: full connection string (overrides individual vars above)
# DATABASE_URL=postgresql://ticketadmin:secretpassword@localhost:5432/ticketbooking

PORT=5000
NODE_ENV=development

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Optional: full Redis URL (overrides individual vars above)
# REDIS_URL=redis://localhost:6379

# JWT — MUST be at least 32 characters in production
JWT_SECRET=super_secret_jwt_signature_key_2026_changeme
JWT_EXPIRES_IN=7d
ADMIN_EMAILS=admin@example.com

# Feature settings
SEAT_LOCK_TTL=600
BOOKING_EXPIRY_MINUTES=11

# Frontend origin for CORS + Socket.io
CORS_ORIGIN=http://localhost:5173

# Client-side (Vite)
VITE_API_URL=http://localhost:5000/api
